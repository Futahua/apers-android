# Build artifacts (generated by scripts/build-apk.sh)
/build/
/dist/
/out/
*.apk
*.apk.idsig
*.aligned.apk

# Signing material — NEVER commit
*.jks
*.keystore
*.p12
*.pem
keystore-password.txt
keystore.properties

# Device logs / captured output that may contain secrets
*.logcat
logcat-*.txt

# Local tool caches
/tools/
/.idea/
*.iml
